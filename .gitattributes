# Normalize all text to LF in the repo AND on every checkout (Windows + Linux), so file hashes
# (the Gate-2 manifest, cco/manifest_tool.py) are stable cross-platform. The canonical scoring
# rerun is on Linux; a manifest must hash the same bytes everyone checks out.
* text=auto eol=lf

# Binary assets — never normalize.
*.png binary
*.ncu-rep binary
*.nsys-rep binary
*.sqlite binary
